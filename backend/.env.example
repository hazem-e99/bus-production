# Backend production environment
NODE_ENV=production
PORT=7126

# Local MongoDB on VPS
MONGODB_URI=mongodb://127.0.0.1:27017/bus-system
DB_NAME=bus-system

# Security
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRATION=7d

# CORS: comma-separated allowed origins
CORS_ORIGIN=https://el-renad.com,https://www.el-renad.com,http://localhost:3000

# Uploads folder (absolute path is recommended on VPS)
UPLOAD_DIR=/var/www/production2026/backend/uploads

# Optional mail settings (required if forgot-password emails are enabled)
MAIL_USER=
MAIL_PASS=
